{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "types": ["cypress"],
    "moduleResolution": "bundler",
    "module": "esnext",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "noEmit": true,
    "isolatedModules": true
  },
  "include": ["**/*.ts", "../cypress.config.ts"]
}
