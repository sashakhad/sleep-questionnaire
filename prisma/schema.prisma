// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model QuestionnaireResponse {
  id           String   @id @default(cuid())
  responseCode String   @unique // User-facing code to retrieve their data
  rawData      Json     // Full questionnaire data
  
  // Denormalized demographics for easy querying/CSV
  yearOfBirth  Int?
  sex          String?
  zipcode      String?
  weight       Float?
  height       Float?
  
  createdAt    DateTime @default(now())

  @@index([responseCode])
}
